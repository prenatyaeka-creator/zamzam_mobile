rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Aturan untuk koleksi users
    match /users/{userId} {
      allow read, write: if request.auth != null;
    }
    
    // Aturan untuk koleksi services (layanan laundry)
    match /services/{serviceId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null; // Di tahap produksi, sebaiknya hanya admin yang bisa menulis
    }
    
    // Aturan untuk koleksi orders (pesanan) dan sub-koleksi histories di dalamnya
    match /orders/{orderId} {
      allow read, write: if request.auth != null;
      
      match /histories/{historyId} {
        allow read, write: if request.auth != null;
      }
    }
    
    // Aturan untuk koleksi transactions (transaksi/pembayaran)
    match /transactions/{transactionId} {
      allow read, write: if request.auth != null;
    }
    
    // Aturan untuk koleksi chat_rooms dan sub-koleksi messages (fitur chat)
    match /chat_rooms/{roomId} {
      allow read, write: if request.auth != null;
      
      match /messages/{messageId} {
        allow read, write: if request.auth != null;
      }
    }
  }
}
